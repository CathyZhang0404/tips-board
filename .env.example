# Copy to CLOVER_Tips/.env and/or tip_dashboard/.env (same folder as main.py).
# Restart uvicorn after any change.

# --- Business timezone (required on Render / UTC servers; optional locally) ---
# IANA name: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
# APP_TIMEZONE=America/New_York

# --- Clover (required for payments) ---
CLOVER_BASE_URL=https://api.clover.com
CLOVER_MERCHANT_ID=
CLOVER_API_TOKEN=

# --- Outbound email (Confirm & Send) ---
#
# Option A — SMTP (works on your laptop; Render FREE tier blocks ports 25/465/587)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=you@gmail.com
SMTP_PASSWORD=
SMTP_FROM_EMAIL=you@gmail.com
#
# Option B — Resend HTTPS API (use on Render free: https://resend.com — get API key)
# RESEND_API_KEY=re_xxxxxxxx
# RESEND_FROM_EMAIL=onboarding@resend.dev

# --- Optional: cloud / Render (also set these in Render dashboard → Environment) ---
# Keep the SQLite DB on a PERSISTENT DISK so confirmed days survive redeploys.
# On Render: add a Disk mounted at /var/data, then set this. Without it, data is wiped.
# DB_PATH=/var/data/tip_board.db
# If set, overrides SQLite manager email on every app start.
# MANAGER_EMAIL=manager@example.com
# If present, forces test mode on startup: true / 1 / yes / on vs false.
# TEST_MODE_EMAIL_ONLY=false
